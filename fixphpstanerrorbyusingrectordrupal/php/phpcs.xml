<?xml version="1.0"?>
<ruleset name="Drupal PHP Compatibility">

  <description>Check PHP compatibility for Drupal project</description>

  <!-- Use PHPCompatibility rules -->
  <rule ref="PHPCompatibility"/>

  <!-- Target PHP 8.4 -->
  <config name="testVersion" value="8.4-"/>

  <!-- Limit scan to custom code -->
  <file>web/modules/contrib</file>
  <file>web/themes/custom</file>

  <!-- Exclude unnecessary paths -->
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/core/*</exclude-pattern>

  <!-- Better output -->
  <arg name="colors"/>
  <arg name="parallel" value="4"/>
  <arg value="p"/>

</ruleset>